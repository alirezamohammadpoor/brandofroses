{% doc %}

  Filter pill
  ------------------------------------------------------------------------------

  Renders one pill-dropdown for a single `collection.filters[]` entry.
  Supports `list`, `price_range`, and `boolean` filter types.

  @param {object} filter - Shopify collection filter (required)
  @param {number} index - Loop index (used for unique IDs) (required)

  @example
    {% for f in collection.filters %}
      {% render 'filter-pill', filter: f, index: forloop.index %}
    {% endfor %}

{% enddoc %}

{%- liquid
  assign panel_id = 'filter-panel-' | append: index
  assign panel_key = 'filter-' | append: index

  comment
    A filter is "active" (visually filled) when any of its values are applied.
    For price_range, check min/max; for list and boolean, check active_values.
  endcomment
  assign has_active = false
  if filter.active_values.size > 0
    assign has_active = true
  endif
  if filter.type == 'price_range'
    if filter.min_value.value or filter.max_value.value
      assign has_active = true
    endif
  endif
-%}

<div class="pill-dropdown" data-component="pill-dropdown">
  <nav class="pill-dropdown__nav">
    <button
      type="button"
      class="pill-dropdown__item pill-dropdown__item--toggle{% if has_active %} pill-dropdown__item--filled{% endif %}"
      data-pill-toggle
      data-panel-key="{{ panel_key }}"
      aria-controls="{{ panel_id }}"
      aria-expanded="false"
    >
      <span>{{ filter.label }}</span>
      <span class="pill-dropdown__caret" aria-hidden="true">▾</span>
    </button>
  </nav>

  <div
    id="{{ panel_id }}"
    class="pill-dropdown__panel pill-dropdown__panel--filter"
    data-panel-key="{{ panel_key }}"
  >
    <div class="pill-dropdown__panel-inner">
      {% case filter.type %}
        {% when 'list' %}
          <ul class="pill-dropdown__panel-list filter-values">
            {% for value in filter.values %}
              {%- liquid
                assign is_disabled = false
                if value.count == 0 and value.active == false
                  assign is_disabled = true
                endif
              -%}
              <li>
                <label class="filter-value{% if value.active %} filter-value--active{% endif %}{% if is_disabled %} filter-value--disabled{% endif %}">
                  <input
                    type="checkbox"
                    name="{{ value.param_name }}"
                    value="{{ value.value | escape }}"
                    class="sr-only"
                    data-filter-input
                    {% if value.active %}checked{% endif %}
                    {% if is_disabled %}disabled{% endif %}
                  >
                  <span class="filter-value__label">{{ value.label }}</span>
                </label>
              </li>
            {% endfor %}
          </ul>

        {% when 'price_range' %}
          <div class="filter-price">
            <label class="filter-price__field">
              <span class="sr-only">{{ 'collections.filters.min_price' | t | default: 'Min price' }}</span>
              <input
                type="number"
                name="{{ filter.min_value.param_name }}"
                value="{{ filter.min_value.value }}"
                placeholder="{{ 'collections.filters.min' | t | default: 'Min' }}"
                min="0"
                inputmode="numeric"
                data-filter-input
              >
            </label>
            <span class="filter-price__sep" aria-hidden="true">–</span>
            <label class="filter-price__field">
              <span class="sr-only">{{ 'collections.filters.max_price' | t | default: 'Max price' }}</span>
              <input
                type="number"
                name="{{ filter.max_value.param_name }}"
                value="{{ filter.max_value.value }}"
                placeholder="{{ 'collections.filters.max' | t | default: 'Max' }}"
                min="0"
                inputmode="numeric"
                data-filter-input
              >
            </label>
          </div>

        {% when 'boolean' %}
          <ul class="pill-dropdown__panel-list filter-values">
            <li>
              <label class="filter-value{% if filter.active_values.first %} filter-value--active{% endif %}">
                <input
                  type="checkbox"
                  name="{{ filter.true_value.param_name }}"
                  value="1"
                  class="sr-only"
                  data-filter-input
                  {% if filter.active_values.first %}checked{% endif %}
                >
                <span class="filter-value__label">{{ filter.label }}</span>
              </label>
            </li>
          </ul>
      {% endcase %}
    </div>
  </div>
</div>
