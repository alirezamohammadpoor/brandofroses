{% doc %}
  @param {product} product - The product to display - required
  @param {string} [loading] - Optional loading attribute for the image - defaults to "lazy"
  @param {string} [sizes] - Optional sizes attribute for the image
  @param {number} [image_min_width] - Optional minimum width for the image - defaults to 500
  @param {number} [image_max_width] - Optional maximum width for the image - defaults to 900
  @param {object} [collection] - Optional collection the product was reached from; used to build `within:` URLs for PDP breadcrumb context

  Badge priority (first match wins):
    1. SOLD OUT   — !product.available        — bg-accent + text-bg (matches sold-out ATC state)
    2. -XX%       — compare_at_price > price  — bg-accent + text-bg
    3. PRE-ORDER  — tag `badge:pre-order`     — bg-fg + text-bg
    4. NEW        — tag `badge:new`           — bg-accent + text-bg (Figma 38:21)

  Badge visual spec (inline classes on the span — see line ~170):
  10px Inter Medium uppercase, 12px line-height, 0.5px tracking,
  8px horizontal + 3px vertical padding, 4px rounded corners.

  @example
  {% render 'product-card',
             product: product,
             loading: 'eager',
             collection: collection
  %}
{% enddoc %}

{% if product %}
  {%- liquid
    if image_min_width == blank
      assign image_min_width = 500
    endif

    if image_max_width == blank
      assign image_max_width = 900
    endif

    capture image_widths
      render 'image-widths', min_width: image_min_width, max_width: image_max_width
    endcapture

    if loading == blank
      assign loading = 'lazy'
    endif

    if sizes == blank
      assign sizes = '(max-width: 767.98px) 50vw, (max-width: 1023.98px) 33vw, 25vw'
    endif

    assign product_url = product.url
    if collection and collection.handle != 'all'
      assign product_url = product.url | within: collection
    endif

    assign current_variant = product.selected_or_first_available_variant
    assign on_sale = false
    assign discount_pct = 0
    if current_variant.compare_at_price > current_variant.price
      assign on_sale = true
      assign discount_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price
    endif

    assign badge_text = blank
    assign badge_classes = ''
    if product.available == false
      assign badge_text = 'products.product.sold_out' | t | upcase
      assign badge_classes = 'bg-accent text-bg'
    elsif on_sale
      assign badge_text = '-' | append: discount_pct | append: '%'
      assign badge_classes = 'bg-accent text-bg'
    else
      for tag in product.tags
        if tag == 'badge:pre-order'
          assign badge_text = 'products.product.pre_order' | t | upcase
          assign badge_classes = 'bg-fg text-bg'
          break
        elsif tag == 'badge:new'
          assign badge_text = 'products.product.new' | t | upcase
          assign badge_classes = 'bg-accent text-bg'
          break
        endif
      endfor
    endif
  -%}

  {%- capture alt_text %}
    {% if product.featured_image.alt %}
      {{ product.featured_image.alt }}
    {% else %}
      "{{ product.title }}" Featured Image
    {% endif %}
  {%- endcapture %}
  {% assign alt_text = alt_text | strip_newlines | strip %}

  {%- assign card_title_id = 'ProductCardTitle-' | append: product.id -%}

  {%- comment -%}
    `relative` (= `position: relative`) on the card root is load-bearing.
    Swatches + price blocks inside the card contain `.sr-only` spans which
    are `position: absolute`. Without a positioned ancestor on the card
    itself, those spans anchor to `<html>` (the initial containing block)
    and escape the parent scroll container's overflow clipping — their
    static-position x-coordinates end up at the card's document position
    (e.g. 3100px+ for the 10th card in a "You may also like" rail) and
    inflate `documentElement.scrollWidth`, cascading into visible horizontal
    overflow on the page. `position: relative` scopes their absolute
    positioning to the card so the scroll container's `overflow-x: auto`
    clips them cleanly.
  {%- endcomment -%}
  <article
    class="product-card group h-full pb-6 relative"
    data-component="product-card"
    aria-labelledby="{{ card_title_id }}"
  >
    <a href="{{ product_url }}" class="flex flex-col gap-2" tabindex="-1" aria-hidden="true">
      {%- comment -%}
        Image — 1:1 ratio. Source product photos are roughly square, so a
        square container sidesteps the baked-in vertical whitespace we saw
        with the earlier 3:4 container (Figma frame 85:80 is 3:3.88, but
        matches the render, not the source images).
      {%- endcomment -%}
      <div class="relative w-full aspect-square overflow-hidden bg-bg-surface">
        {{ product.featured_image
          | image_url: width: image_max_width
          | image_tag:
            loading: loading,
            widths: image_widths,
            alt: alt_text,
            class: 'h-full w-full object-cover lazy-image absolute inset-0 transition-opacity duration-300 group-hover:opacity-0',
            sizes: sizes
        }}

        {%- comment -%} Hover image — second image whose alt matches the featured color {%- endcomment -%}
        {%- assign featured_color = product.selected_or_first_available_variant.option1 | upcase -%}
        {%- assign hover_image = nil -%}
        {%- assign color_image_count = 0 -%}
        {%- for image in product.images -%}
          {%- assign image_alt_up = image.alt | upcase -%}
          {%- if image_alt_up contains featured_color -%}
            {%- assign color_image_count = color_image_count | plus: 1 -%}
            {%- if color_image_count == 2 -%}
              {%- assign hover_image = image -%}
              {%- break -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        {% if hover_image %}
          {{ hover_image
            | image_url: width: image_max_width
            | image_tag:
              loading: 'lazy',
              widths: image_widths,
              alt: alt_text,
              class: 'h-full w-full object-cover absolute inset-0 transition-opacity duration-300 opacity-0 group-hover:opacity-100',
              sizes: sizes
          }}
        {% endif %}

        {%- comment -%}
          Badge spec — Figma 38:21 (PLP Product Card > Badge): 10px
          Inter Medium uppercase, 12px line-height, 0.5px tracking,
          `bg-accent` + `text-bg` for NEW / -XX% states. Inline classes
          here instead of the shared `text-section-label` utility —
          that utility is also used by the `+N` color-overflow chip
          further down in this file (line ~246), and the chip's looser
          line-height + tracking (`text-section-label` = 140% +
          0.08em) read fine there; tightening the utility would drift
          the chip off-spec too.
        {%- endcomment -%}
        {% if badge_text != blank %}
          <span class="absolute top-2 left-2 text-[10px] font-medium uppercase tracking-[0.5px] leading-[12px] {{ badge_classes }} px-2 py-[3px] rounded-[4px]">
            {{ badge_text }}
          </span>
        {% endif %}
      </div>
    </a>

    {%- comment -%}
      Meta — outside the outer <a> so swatches don't navigate.
      Layout (Figma 187:474, adapted per product spec):
        Row 1: title
        Row 2: price (sale-aware)
        Row 3: color name — secondary muted text, selected variant's color
        Row 4: swatches — visual only, no interaction (click the title / image)

      Vertical rhythm: 4px between all text rows (`gap-1`), and the swatches
      get an additional `mt-1` so the visual block sits 8px below the color
      name text. The 8px gap from image to meta block is the `mt-2` wrapper.
    {%- endcomment -%}

    {%- liquid
      assign color_option = nil
      for option in product.options_with_values
        if option.name == 'Color'
          assign color_option = option
          break
        endif
      endfor
    -%}

    <div class="mt-2 flex flex-col gap-1">
      {%- comment -%} Title {%- endcomment -%}
      <a
        href="{{ product_url }}"
        id="{{ card_title_id }}"
        class="text-caption text-fg uppercase truncate"
      >{{ product.title }}</a>

      {%- comment -%} Price — strikethrough compare + sale price when on sale {%- endcomment -%}
      <div class="flex items-center gap-2 text-caption">
        {% if on_sale %}
          <s class="text-muted" aria-hidden="true">
            {{ current_variant.compare_at_price | money_without_trailing_zeros }}
          </s>
          <span class="text-accent font-medium">
            <span class="sr-only">{{ 'products.product.price.sale_price' | t }}</span>
            {{ current_variant.price | money_without_trailing_zeros }}
          </span>
          <span class="sr-only">
            {{ 'products.product.price.regular_price' | t }}
            {{ current_variant.compare_at_price | money_without_trailing_zeros }}
          </span>
        {% else %}
          <span class="text-fg">
            {{ current_variant.price | money_without_trailing_zeros }}
          </span>
        {% endif %}
      </div>

      {% if color_option %}
        {%- comment -%} Color name — reflects the currently-selected variant {%- endcomment -%}
        <p class="text-caption text-muted uppercase">{{ color_option.selected_value }}</p>

        {%- comment -%}
          Swatches — visual only. Show the first 3; spill the rest into a
          `+N` chip so cards stay compact regardless of how many colors a
          product has. The label / card click takes the user to the PDP
          where they can actually pick a variant.

          `!= blank` catches both `nil` and empty-string swatch colors
          (some Shopify swatch entries ship with `""` which would defeat a
          plain truthiness check and render invisible circles).
        {%- endcomment -%}
        {%- assign color_count = color_option.values.size -%}
        {%- assign max_visible = 3 -%}
        {%- assign overflow = color_count | minus: max_visible -%}
        <ul
          class="flex items-center gap-1 mt-1"
          role="list"
          aria-label="{{ 'products.product.available_colors' | t }}"
        >
          {% for value in color_option.values limit: max_visible %}
            <li
              class="block w-2.5 h-2.5 rounded-full border border-muted/30"
              style="background-color: {% if value.swatch.color != blank %}{{ value.swatch.color }}{% else %}#1A1A18{% endif %};"
              title="{{ value }}"
            ><span class="sr-only">{{ value }}</span></li>
          {% endfor %}
          {% if overflow > 0 %}
            <li
              class="text-section-label text-muted ml-1"
              aria-label="{{ 'products.product.more_colors' | t: count: overflow }}"
            >+{{ overflow }}</li>
          {% endif %}
        </ul>
      {% endif %}
    </div>
  </article>
{% endif %}
