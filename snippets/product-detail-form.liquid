{% # theme-check-disable RemoteAsset %}
{% # theme-check-disable UnusedAssign %}

{% doc %}
  Product Detail Form

  @param {object} product - The product to display - required
  @param {object} [current_variant] - The current variant to display - optional
  @param {object} [current_collection] - The collection the product was reached from (for breadcrumb) - optional

  @example
    {% render 'product-detail-form',
              product: product,
              current_variant: current_variant,
              current_collection: collection
    %}
{% enddoc %}

{% unless product == empty %}

  {%- liquid
    assign current_variant = current_variant | default: product.selected_or_first_available_variant
  %}

  <div
    class="h-full"
    data-component="product-detail-form"
  >
    {% form 'product', product, style: 'height: 100%' %}
      <div class="lg:sticky lg:top-[var(--chrome-height)] lg:min-h-[calc(100dvh-var(--chrome-height))] lg:flex lg:items-center lg:justify-center">
        {%- comment -%}
          Info-column inner width — Figma 6:2 spec is a 650px column with
          48px horizontal padding (554px content). Using `lg:w-[560px]`
          as a FIXED width so the column renders identically across
          products regardless of inner content length. Earlier
          `lg:w-full lg:max-w-[560px]` let the flex algorithm size the
          item to content in some cases (e.g. Beanie product with no
          size picker → narrower column than products with a size row),
          which made the ATC button width + inner content jump between
          PDPs. `lg:max-w-full` on top caps if the parent column is
          ever narrower than 560px (rare — only at the exact lg
          breakpoint 1024px where each half-column = 512px).
          `lg:px-12` echoes Figma's 48px gutter.
        {%- endcomment -%}
        <div class="px-2 py-6 lg:py-10 lg:px-12 lg:w-[560px] lg:max-w-full lg:shrink-0">

          {%- comment -%}
            Breadcrumb parent collection, fallback chain:
              1. custom.primary_collection metafield — merchant-pinned authoritative parent
              2. current_collection — collection the visitor arrived from (if any)
              3. product.collections.first — last-resort default
          {%- endcomment -%}
          {%- liquid
            assign breadcrumb_col = product.metafields.custom.primary_collection.value | default: current_collection | default: product.collections.first
            assign breadcrumb_parent = nil
            assign main_menu = linklists['main-menu']
            if breadcrumb_col and main_menu
              for link in main_menu.links
                for sublink in link.links
                  assign sub_handle = sublink.url | split: '/collections/' | last | split: '?' | first
                  if sub_handle == breadcrumb_col.handle
                    assign breadcrumb_parent = link
                    break
                  endif
                endfor
                if breadcrumb_parent
                  break
                endif
              endfor
            endif
          -%}
          {% if breadcrumb_col %}
            <nav class="mb-3" aria-label="Breadcrumb">
              <ol class="flex items-center gap-1 text-[12px] text-muted uppercase">
                {% if breadcrumb_parent and breadcrumb_parent.title != breadcrumb_col.title %}
                  <li><a href="{{ breadcrumb_parent.url }}">{{ breadcrumb_parent.title }}</a></li>
                  <li>/</li>
                {% endif %}
                <li><a href="{{ breadcrumb_col.url }}">{{ breadcrumb_col.title }}</a></li>
                <li>/</li>
                <li>{{ product.title }}</li>
              </ol>
            </nav>
          {% endif %}

          {%- comment -%} Title — Figma 6:2 spec: 28px bold uppercase on desktop {%- endcomment -%}
          <h1 class="text-[20px] lg:text-[28px] font-bold text-left text-fg uppercase mb-2">
            {{ product.title }}
          </h1>

          {%- comment -%} Price — 14px uppercase, wraps the product-detail-price snippet which has no sizing of its own {%- endcomment -%}
          <div class="text-left text-[14px] text-fg uppercase mb-6">
            {% render 'product-detail-price',
                      product: product,
                      current_variant: current_variant
            %}
          </div>

          {%- comment -%}
            Product description — short tagline + "Read more" toggle that
            expands the full description below with the same animation
            pattern used for the info accordion (see `.collapsible` /
            `collapsible-toggle` in `_collapsible.css` +
            `collapsibleToggle.ts`). The short-line summary is the
            description itself truncated to two lines via `line-clamp-2`;
            the full description repeats underneath inside the collapsible
            panel so the text animates in instead of the clamp unsnapping
            abruptly. The button label swaps on expand by listening for
            the parent's `aria-expanded` state via CSS, not a separate
            class toggle — keeps a single source of truth.
          {%- endcomment -%}
          {% if product.description != blank %}
            {%- assign desc_id = 'product-desc-' | append: product.id -%}
            {%- assign desc_toggle_id = desc_id | append: '-toggle' -%}
            <div class="mb-6">
              {%- comment -%}
                Single-copy description that max-height-animates between
                a 40px (2-line) clamped preview and its full height. See
                `_collapsible.css::.description-expander__content` for
                the animation math and the rationale for not using
                `.collapsible` (which starts at 0 height, not 2 lines).
                The `CollapsibleToggle` component flips `is-open` here
                just like it does on info-accordion panels.
              {%- endcomment -%}
              <div
                id="{{ desc_id }}"
                class="description-expander__content"
                role="region"
                aria-labelledby="{{ desc_toggle_id }}"
              >
                <div class="description-expander__text text-[12px] text-fg uppercase leading-5">
                  {{ product.description }}
                </div>
              </div>
              <button
                type="button"
                id="{{ desc_toggle_id }}"
                class="collapsible-toggle group mt-2 text-[10px] text-muted uppercase tracking-[0.04em] underline cursor-pointer"
                aria-expanded="false"
                aria-controls="{{ desc_id }}"
                aria-label="{{ 'products.toggle_description' | t }}"
                data-component="collapsible-toggle"
              >
                <span class="group-aria-expanded:hidden">{{ 'products.read_more' | t }}</span>
                <span class="hidden group-aria-expanded:inline">{{ 'products.read_less' | t }}</span>
              </button>
            </div>
          {% endif %}

          {%- comment -%}
            Brand-specific variant group (e.g. sibling products with different heel heights,
            frame sizes, bottle volumes, etc.) was intentionally removed in the template.
            Re-introduce here per brand. Pattern:

              {%- assign siblings = product.metafields.custom.<your_key>.value -%}
              {% if siblings != blank %}
                …render sibling picker…
              {% endif %}
          {%- endcomment -%}

          <div itemprop="offers" itemscope itemtype="http://schema.org/Offer">
            <meta itemprop="priceCurrency" content="{{ shop.currency }}">
            <meta itemprop="price" content="{{ current_variant.price | divided_by: 100.00 }}">
            <link itemprop="availability" href="http://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}">

            {%- comment -%} Variant Picker {%- endcomment -%}
            <div
              data-component="variant-picker"
              class="flex flex-col gap-6"
              {% if product.has_only_default_variant %}
                style="display: none;"
                aria-hidden="true"
              {% endif %}
            >
              {% for option in product.options_with_values %}
                {%- liquid
                  assign option_name_handle = option.name | handle
                  assign selection_type = 'select'

                  if option_name_handle == 'color'
                    assign selection_type = 'radio'
                  endif

                  if option_name_handle == 'size'
                    assign selection_type = 'radio'
                  endif
                -%}

                <div>
                  {% render 'variant-picker-option',
                            option: option,
                            product: product,
                            selection_type: selection_type
                  %}
                </div>
              {% endfor %}
            </div>

            {%- comment -%} No-JS variant select fallback {%- endcomment -%}
            <label class="sr-only" for="no-js-variant-select">Select Variant</label>
            <select name="id" class="no-js" id="no-js-variant-select">
              {% for variant in product.variants %}
                <option
                  {% if variant == current_variant %}selected="selected"{% endif %}
                  {% unless variant.available %}disabled="disabled"{% endunless %}
                  value="{{ variant.id }}"
                >
                    {{ variant.title }}
                </option>
              {% endfor %}
            </select>

            <input type="hidden" value="1" name="quantity" />

            {%- comment -%}
              Add to Bag button
              ------------------------------------------------------------
              Two state visual per Figma 173:446:
                Default — `bg-fg-dark` + `text-bg`, label left + price right
                          (`justify-between`).
                Disabled — `bg-muted` + `text-accent`, label centered
                           (`justify-center`), price hidden entirely.
              The disabled variant is handled by:
                - `disabled:*` utilities on the button itself for bg / text
                  color / justify
                - a CSS rule in `_styles/core/_forms.css` that hides the
                  nested price span when the button is :disabled (Tailwind
                  doesn't expose a `parent-disabled:` variant, so one CSS
                  rule is simpler than fighting arbitrary-variant syntax).
              Inline markup (not the shared `button` snippet) — this
              button needs a two-child layout that the shared snippet
              can't express.
            {%- endcomment -%}
            {%- comment -%}
              `data-sold-out` vs `disabled`:
                - `data-sold-out` is the VISUAL red state (Figma 173:446
                  disabled variant — bg-muted + text-accent + centered
                  label + price hidden). Applied only when the variant is
                  actually unavailable.
                - `disabled` is the FUNCTIONAL gate (blocks clicks) and is
                  also toggled TRANSIENTLY during form submit to keep the
                  user from double-clicking. We can't hang the red visual
                  on `:disabled` because then the "Adding..." state (which
                  momentarily sets `disabled` via JS) would also flash
                  red — not what we want.
            {%- endcomment -%}
            <button
              type="submit"
              name="add"
              class="w-full h-12 rounded-[6px] flex items-center px-6 mt-6 text-[14px] font-medium uppercase tracking-[0.5px] bg-fg-dark text-bg justify-between data-[sold-out]:bg-accent data-[sold-out]:text-bg data-[sold-out]:justify-center disabled:cursor-not-allowed"
              {% if current_variant.available == false %}
                disabled="disabled"
                data-sold-out
              {% endif %}
              data-component="atc-button"
            >
              <span data-label>
                {% if current_variant.available %}
                  {{ 'app.add_to_cart' | t }}
                {% else %}
                  {{ 'app.sold_out' | t }}
                {% endif %}
              </span>
              <span data-atc-price class="font-normal">
                {{ current_variant.price | money_without_trailing_zeros }}
              </span>
            </button>

            <div>
              <div>
                {{ form | payment_terms }}
              </div>
            </div>

            {%- comment -%}
              Match With (left) + Model Info (right) share a horizontal row.
                - Match With = merchant-curated companion products (metafield
                  `custom.match_with`). Each pairing renders as a horizontal
                  card (image + title + color dots + price) stacked
                  vertically — see `product-match-with.liquid`. Left side,
                  `flex-1 min-w-0` takes remaining width after Model Info.
                - Model Info = fit-reference card (metaobject
                  `custom.model` + `custom.model_size`, Figma 29:19).
                  Right side, shrinks to content.
              Each snippet renders nothing when its metafield is empty, so
              the wrapper guards against empty `mt-10` dead space by only
              rendering when at least one side has content. Placed here —
              directly below ATC + payment terms — so the fit and pairing
              info live in the purchase-decision zone rather than buried
              under the info tabs.
            {%- endcomment -%}
            {%- comment -%}
              Wrapper is conditional on at least one side having content.
              Both snippets re-check their own metafield internally; the
              guard here is only to avoid an empty `mt-10` + `gap-2` row
              when everything is unset.
            {%- endcomment -%}
            {% if product.metafields.custom.match_with.value.size > 0 or product.metafields.custom.model.value.name != blank %}
              {%- comment -%}
                Row width math — same `flex-1 + gap-2` split at every
                breakpoint so each card is always exactly 3 variant
                tiles wide on its own row.

                Desktop: info column content 464px. Variant tiles
                sit at `flex-1` inside a `gap-x-2` (8px) row; with 6
                sizes each tile = (464 − 5×8) / 6 ≈ 70.67px. Three
                tiles + 2 gaps = 228px. Mirror `gap-2` here so each
                card = (464 − 8) / 2 = 228px.

                Mobile: info column content ~359px (375 viewport
                − 16px `px-2`). Six tiles each = (359 − 40) / 6 ≈
                53px. Three tiles + 2 gaps = 175px. Mirror `gap-2`
                here so each card = (359 − 8) / 2 = 175.5px. Content
                inside the card (48px image + text) is designed to
                truncate cleanly at this width — title + meta lines
                use `truncate` / line-clamp so they degrade to
                ellipsis rather than overflowing.
              {%- endcomment -%}
              <div class="mt-10 flex items-start gap-2">
                <div class="flex-1 min-w-0">
                  {% render 'product-match-with', product: product %}
                </div>
                <div class="flex-1 min-w-0">
                  {% render 'product-model-info', product: product %}
                </div>
              </div>
            {% endif %}

            {%- comment -%}
              Info accordion — Figma 6:2: 48px rows with 12px medium
              uppercase label + `›` chevron. Each row expands in place
              via the shared `.collapsible` / `collapsible-toggle`
              primitive (same pattern used for the Read more / Read
              less description toggle below — and `_collapsible.css`
              + `collapsibleToggle.ts` are the single source of truth
              for the 500ms grid-template-rows animation and the
              chevron rotation triggered by `aria-expanded`).

              Content per row comes from per-product metafields
              (namespace `custom`): product_details, size_guide,
              care_instructions, shipping_returns. Each has a
              fallback copy string so the row renders something
              meaningful even on un-populated products.
            {%- endcomment -%}
            {%- comment -%}
              Content + fallback resolution is branched per row via a
              `case` statement rather than being zipped together via a
              synthetic `|||` delimiter + `split` (earlier iteration
              did that; footgun if a merchant enters literal `|||` in
              any of the four metafields — the split would desync
              content against fallbacks across all rows). Reading
              `row → content` top-to-bottom is also just more obvious.
            {%- endcomment -%}
            <div class="mt-10">
              {%- assign info_rows = 'product-details,size-guide,care-instructions,shipping-returns' | split: ',' -%}
              {% for row in info_rows %}
                {%- liquid
                  case row
                    when 'product-details'
                      assign row_label = 'products.info.product_details' | t
                      assign row_content = product.metafields.custom.product_details
                      assign row_fallback = 'Describe construction, materials, and fit here. Populate per product via the `custom.product_details` metafield.'
                    when 'size-guide'
                      assign row_label = 'products.info.size_guide' | t
                      assign row_content = product.metafields.custom.size_guide
                      assign row_fallback = 'Replace with the brand’s size guide. Consider a metafield (`custom.size_guide`) if sizing differs per product.'
                    when 'care-instructions'
                      assign row_label = 'products.info.care_instructions' | t
                      assign row_content = product.metafields.custom.care_instructions
                      assign row_fallback = 'Describe care instructions here (wash, dry, iron). Populate per product via the `custom.care_instructions` metafield.'
                    when 'shipping-returns'
                      assign row_label = 'products.info.shipping_returns' | t
                      assign row_content = product.metafields.custom.shipping_returns
                      assign row_fallback = 'Describe shipping and returns policy here. Can be overridden per product via the `custom.shipping_returns` metafield.'
                  endcase
                  assign panel_id = 'product-info-' | append: row | append: '-' | append: product.id
                  assign toggle_id = panel_id | append: '-toggle'
                -%}
                <div class="h-px bg-muted/30 w-full" aria-hidden="true"></div>
                <button
                  type="button"
                  id="{{ toggle_id }}"
                  class="collapsible-toggle w-full h-12 flex items-center justify-between text-left"
                  aria-expanded="false"
                  aria-controls="{{ panel_id }}"
                  data-component="collapsible-toggle"
                >
                  <span class="text-label-tight text-fg">
                    {{ row_label }}
                  </span>
                  <span class="text-[16px] text-muted" aria-hidden="true" data-chevron>›</span>
                </button>
                <div
                  id="{{ panel_id }}"
                  class="collapsible"
                  role="region"
                  aria-labelledby="{{ toggle_id }}"
                >
                  <div class="collapsible__inner">
                    <p class="pb-4 text-[12px] text-fg leading-relaxed">
                      {{ row_content | default: row_fallback }}
                    </p>
                  </div>
                </div>
              {% endfor %}
              <div class="h-px bg-muted/30 w-full" aria-hidden="true"></div>
            </div>
          </div>
        </div>
      </div>

      <script type="application/json" data-product-json>
        {% render 'product-json-lite', product: product %}
      </script>
    {% endform %}
  </div>

{% endunless %}
