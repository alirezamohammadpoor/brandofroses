{% doc %}

  Cart Footer
  ------------------------------------------------------------------------------

  Renders the sticky footer of the ajax cart:
  - free shipping progress (hidden when threshold is 0 or unlocked)
  - subtotal
  - checkout button

  @param {number} threshold - Free shipping threshold in store currency (0 = hide)

  @example
    {% render 'cart-footer', threshold: section.settings.free_shipping_threshold %}
{% enddoc %}

{%- liquid
  assign threshold_cents = threshold | default: 0 | times: 100
  assign remaining_cents = threshold_cents | minus: cart.items_subtotal_price
-%}

<div
  class="ajax-cart__footer"
  data-component="cart-footer"
>
  {% if threshold_cents > 0 %}
    <p
      class="text-[11px] text-muted uppercase text-center leading-[16px]"
      data-free-shipping
    >
      {%- if remaining_cents > 0 -%}
        {{ 'ajax_cart.general.free_shipping_progress_html' | t: amount: remaining_cents | money_without_trailing_zeros }}
      {%- else -%}
        {{ 'ajax_cart.general.free_shipping_unlocked' | t }}
      {%- endif -%}
    </p>
  {% endif %}

  <div class="flex justify-between items-center text-label text-fg uppercase">
    <span>{{ 'ajax_cart.general.subtotal' | t }}</span>
    <span data-subtotal-price>{{ cart.items_subtotal_price | money_without_trailing_zeros }}</span>
  </div>

  <button
    type="submit"
    name="checkout"
    class="w-full h-[52px] rounded-md bg-fg-dark text-bg text-[12px] font-medium uppercase tracking-[0.04em] flex items-center justify-center"
  >
    {{ 'ajax_cart.general.checkout' | t | upcase }}
  </button>

  <a
    href="{{ routes.cart_url }}"
    class="text-[11px] text-muted uppercase tracking-[0.04em] text-center block mt-2"
  >
    {{ 'ajax_cart.general.view_cart' | t }}
  </a>
</div>
