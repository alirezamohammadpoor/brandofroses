{% doc %}

  Collection toolbar
  ------------------------------------------------------------------------------

  Renders the filter + sort toolbar above the product grid on collection pages.

  Desktop: one pill-dropdown with a tab per entry in `collection.filters`.
           Clicking a tab opens its panel inside the shared pill container —
           only one panel open at a time. Separate sort pill on the right.
           Active filter chips below the pill row.
  Mobile:  A single `FILTER (n)` button that opens the mobile filter drawer,
           sort pill next to it, and the active filter chips row below.

  Wrapped in a single `<form method="get">` so filter inputs serialize to URL
  params on submit. Auto-submits on change via the `collection-toolbar`
  component.

  @example
    {% render 'collection-toolbar' %}

{% enddoc %}

{%- liquid
  assign filters = collection.filters
  assign active_count = 0
  for f in filters
    assign active_count = active_count | plus: f.active_values.size
    if f.type == 'price_range'
      if f.min_value.value or f.max_value.value
        assign active_count = active_count | plus: 1
      endif
    endif
  endfor
-%}

<form
  method="get"
  class="collection-toolbar"
  data-component="collection-toolbar"
  aria-label="{{ 'collections.filters.toolbar_label' | t }}"
>
  {% if filters.size > 0 %}
    {%- comment -%} Desktop: one pill with a tab per filter {%- endcomment -%}
    <div
      class="pill-dropdown collection-toolbar__filter-pill hidden lg:flex"
      data-component="pill-dropdown"
    >
      <nav class="pill-dropdown__nav" aria-label="{{ 'collections.filters.title' | t }}">
        {% for f in filters %}
          {%- liquid
            assign has_active = false
            if f.active_values.size > 0
              assign has_active = true
            endif
            if f.type == 'price_range'
              if f.min_value.value or f.max_value.value
                assign has_active = true
              endif
            endif
          -%}
          <button
            type="button"
            class="pill-dropdown__item pill-dropdown__item--toggle{% if has_active %} pill-dropdown__item--filled{% endif %}"
            data-pill-toggle
            data-panel-key="filter-{{ forloop.index }}"
            aria-controls="collection-filter-panel-{{ forloop.index }}"
            aria-expanded="false"
          >{{ f.label }}</button>
          {% unless forloop.last %}
            <span class="pill-dropdown__divider" aria-hidden="true"></span>
          {% endunless %}
        {% endfor %}
      </nav>

      {% for f in filters %}
        <div
          id="collection-filter-panel-{{ forloop.index }}"
          class="pill-dropdown__panel pill-dropdown__panel--filter"
          data-panel-key="filter-{{ forloop.index }}"
        >
          <div class="pill-dropdown__panel-inner">
            {% render 'filter-values', filter: f %}
          </div>
        </div>
      {% endfor %}
    </div>

    {%- comment -%} Mobile: single Filter button that opens the drawer {%- endcomment -%}
    <div class="collection-toolbar__mobile-filter lg:hidden">
      <button
        type="button"
        class="pill-dropdown__item pill-dropdown__item--toggle collection-toolbar__mobile-filter-btn{% if active_count > 0 %} pill-dropdown__item--filled{% endif %}"
        data-drawer-toggle="collection-filter-drawer"
        aria-controls="collection-filter-drawer"
        aria-expanded="false"
      >
        {%- liquid
          assign label = 'collections.filters.title' | t | upcase
        -%}
        {% if active_count > 0 %}
          {{ label }} ({{ active_count }})
        {% else %}
          {{ label }}
        {% endif %}
      </button>
    </div>
  {% endif %}

  {%- comment -%}
    Desktop chips row (lg:flex) — sits between the filter pill and the
    right-aligned sort pill. On mobile the chips wrap to their own row
    at the bottom of the toolbar via `.collection-toolbar__chips-mobile`
    (flex-basis: 100% in `_collection.css`).
  {%- endcomment -%}
  <div class="collection-toolbar__chips hidden lg:flex">
    {% render 'filter-chips', filters: filters %}
  </div>

  {%- comment -%}
    Sort pill — DESKTOP ONLY (wrapped in `hidden lg:flex`). On mobile
    the sort options live inside the filter drawer as its own
    accordion section at the bottom of the body (see
    `collection-filter-drawer.liquid`), so the mobile toolbar row has
    just the single `[FILTER]` button.

    Same `name="sort_by"` on inputs in both places: the browser treats
    them as a single radio group and keeps selection in sync across
    desktop pill + mobile drawer. Visual `.filter-value--active` state
    is driven by Liquid comparing `option.value == current_sort` at
    render time, not by radio DOM state, so both surfaces render the
    correct selection regardless of which one "wins" the HTML `checked`
    attribute race at parse time.
  {%- endcomment -%}
  <div class="hidden lg:flex">
    {% render 'sort-dropdown',
              sort_options: collection.sort_options,
              current_sort: collection.sort_by | default: collection.default_sort_by
    %}
  </div>

  {%- comment -%} Mobile: chips sit on their own row below the pills {%- endcomment -%}
  <div class="collection-toolbar__chips-mobile lg:hidden">
    {% render 'filter-chips', filters: filters %}
  </div>

  {%- comment -%} Mobile filter drawer — rendered inside the form so its inputs
  are included when the user taps Apply. {%- endcomment -%}
  {% if filters.size > 0 %}
    {% render 'collection-filter-drawer' %}
  {% endif %}
</form>
