{% doc %}

  Collection filter drawer (mobile)
  ------------------------------------------------------------------------------

  Full-screen slide-in drawer that contains all `collection.filters`, stacked
  as `<details>` accordion sections. Uses the shared `.drawer` primitive.

  Must be rendered INSIDE the collection toolbar `<form>` so its inputs are
  included on submit alongside the desktop pill inputs.

  On desktop the drawer is never opened (the desktop pill row is the UI), so
  we render the drawer markup only on mobile breakpoints via CSS.

  @example
    {% render 'collection-filter-drawer' %}

{% enddoc %}

<div
  id="collection-filter-drawer"
  class="drawer collection-filter-drawer lg:hidden"
  data-component="collection-filter-drawer"
  aria-hidden="true"
  role="dialog"
  aria-labelledby="collection-filter-drawer-title"
  inert
>
  <div class="collection-filter-drawer__inner" data-scroller>
    <header class="collection-filter-drawer__header">
      <span id="collection-filter-drawer-title" class="collection-filter-drawer__title">{{ 'collections.filters.title' | t }}</span>
      <button
        type="button"
        class="collection-filter-drawer__close"
        data-close
        aria-label="{{ 'general.close' | t }}"
      >&times;</button>
    </header>

    <div class="collection-filter-drawer__body">
      {% for f in collection.filters %}
        {%- liquid
          assign has_active = false
          if f.active_values.size > 0
            assign has_active = true
          endif
          if f.type == 'price_range'
            if f.min_value.value or f.max_value.value
              assign has_active = true
            endif
          endif
        -%}
        <details class="collection-filter-drawer__group" {% if has_active %}open{% endif %}>
          <summary class="collection-filter-drawer__group-title">
            <span>{{ f.label }}</span>
            <span class="collection-filter-drawer__group-caret" aria-hidden="true">▾</span>
          </summary>

          <div class="collection-filter-drawer__group-body">
            {% render 'filter-values', filter: f %}
          </div>
        </details>
      {% endfor %}
    </div>

    <footer class="collection-filter-drawer__footer">
      {%- comment -%}
        Apply submits the form as a full navigation — the drawer can't stay
        open across a DOM swap, and the AJAX path is only wired for desktop
        change-events. `CollectionToolbar.onSubmit` intercepts this
        submitter to build a deduped URL (native serialization would emit
        duplicate name+value pairs since filter inputs are rendered twice)
        and then navigates via `window.location.href`.

        Label is pre-assigned: Shopify's `render` tag doesn't evaluate
        filter chains on inline args, so `label: '...' | t` leaks the raw
        key through — the translation has to happen before the render call.
      {%- endcomment -%}
      {%- assign apply_label = 'collections.filters.apply' | t -%}
      {% render 'button',
                label: apply_label,
                type: 'submit',
                variant: 'primary',
                size: 'lg',
                block: true
      %}
      <a href="{{ collection.url }}" class="collection-filter-drawer__clear" rel="nofollow">
        {{ 'collections.filters.clear_all' | t }}
      </a>
    </footer>
  </div>
</div>
