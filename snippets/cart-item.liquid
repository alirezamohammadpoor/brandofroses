{% doc %}

  Cart Item
  ------------------------------------------------------------------------------

  @param {object} item - The cart item to display

  @example
    {% render 'cart-item', item: item %}
{% enddoc %}

{% if item != blank %}
  <div
    class="ajax-cart__item"
    data-component="cart-item"
  >
    <div class="ajax-cart__item-inner">
      {%- if item.image -%}
        {%- comment -%}
          object-contain instead of cover — product photos are shot square,
          and in the small 72×96 cart thumb the cropped sides of object-cover
          read as awkward zoom-in. Contain shows the full product with a
          small bg-bg-surface band top/bottom matching the studio backdrop.
        {%- endcomment -%}
        <a href="{{ item.product.url }}" class="block w-[72px] shrink-0 bg-bg-surface">
          <img
            src="{{ item.image | image_url: width: 144 }}"
            alt="{{ item.image.alt | escape }}"
            loading="lazy"
            width="72"
            height="96"
            class="w-full aspect-[3/4] object-contain lazy-image"
          >
        </a>
      {% endif %}

      {%- comment -%}
        Info stack — title, then each option on its own line, then price ×
        qty inline, then qty adjuster + remove on a separate row below.
        Title gets right-padding so the absolute-positioned close button
        doesn't overlap multi-line titles.
      {%- endcomment -%}
      <div class="flex-1 flex flex-col min-w-0 gap-1 relative">
        <button
          class="absolute top-0 right-0 text-fg text-[18px] leading-none p-1 -m-1 cursor-pointer"
          type="button"
          aria-label="{{ 'cart.general.remove_item' | t: title: item.product.title | escape }}"
          data-remove
        >×</button>

        <a href="{{ item.product.url }}" class="text-label text-fg uppercase pr-6">
          {{ item.product.title | escape | upcase }}
        </a>

        {% unless item.product.has_only_default_variant %}
          {% for option in item.options_with_values %}
            <p class="text-[11px] font-medium text-muted uppercase leading-[16px]">
              {{ option.name }}: {{ option.value }}
            </p>
          {% endfor %}
        {% endunless %}

        <p class="text-[12px] font-medium text-fg uppercase">
          {% render 'cart-item-price', item: item %}
        </p>

        <div class="mt-2">
          {%- liquid
            assign max = item.variant.quantity_rule.max

            if max == blank and item.variant.inventory_management != nil and item.variant.inventory_policy == 'deny'
              assign max = item.variant.inventory_quantity
            endif
          -%}

          {%- render 'quantity-adjuster',
                      value: item.quantity,
                      min: 0,
                      max: max,
                      step: item.variant.quantity_rule.increment,
                      input_name: 'updates[]',
                      product_title: item.product.title
          -%}
        </div>
      </div>
    </div>
  </div>
{% endif %}
