<header
  class="header header--{{ section.settings.style | default: 'pill' }}"
  data-section-id="{{ section.id }}"
  data-section-type="header"
  role="banner"
>
  {%- liquid
    assign style = section.settings.style | default: 'pill'
    assign menu = settings.primary_menu
  -%}

  <div class="header__row">
    {%- comment -%} --- Mobile: Menu pill (left) --- {%- endcomment -%}
    <div class="header__mobile-left lg:hidden">
      <button
        type="button"
        class="header__pill-btn"
        data-mobile-menu-toggle
        aria-label="Toggle menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="pill-dropdown__item">Menu</span>
      </button>
    </div>

    {%- comment -%} --- Desktop: Left navigation --- {%- endcomment -%}
    {% if style == 'pill' %}
      <div
        id="desktop-menu-panel"
        class="pill-dropdown hidden lg:flex"
        data-component="pill-dropdown"
      >
        <nav class="pill-dropdown__nav" aria-label="Primary">
          {% if menu != blank %}
            {% for link in menu.links %}
              {% if link.links.size > 0 %}
                <button
                  type="button"
                  class="pill-dropdown__item pill-dropdown__item--toggle"
                  data-pill-toggle
                  data-panel-key="{{ forloop.index0 }}"
                  aria-controls="desktop-menu-panel-{{ forloop.index0 }}"
                  aria-expanded="false"
                >
                  <span>{{ link.title }}</span>
                </button>
              {% else %}
                <a href="{{ link.url }}" class="pill-dropdown__item"{% if link.current %} aria-current="page"{% endif %}>
                  {{ link.title }}
                </a>
              {% endif %}
              {% unless forloop.last %}<span class="pill-dropdown__divider" aria-hidden="true"></span>{% endunless %}
            {% endfor %}
          {% endif %}
        </nav>

        {% if menu != blank %}
          {% for link in menu.links %}
            {% if link.links.size > 0 %}
              <div
                class="pill-dropdown__panel pill-dropdown__panel--menu"
                data-panel-key="{{ forloop.index0 }}"
              >
                <div class="pill-dropdown__panel-inner">
                  <ul
                    id="desktop-menu-panel-{{ forloop.index0 }}"
                    class="pill-dropdown__panel-list"
                    role="menu"
                  >
                    {% for sublink in link.links %}
                      <li role="none">
                        <a
                          href="{{ sublink.url }}"
                          class="pill-dropdown__category"
                          role="menuitem"
                          {% if sublink.current %}aria-current="page"{% endif %}
                        >{{ sublink.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    {% else %}
      {%- comment -%} Flat: wordmark sits on the left {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="header__wordmark header__wordmark--left hidden lg:block" aria-label="{{ shop.name }}">
        {{ shop.name | upcase }}
      </a>
    {% endif %}

    {%- comment -%} --- Center: wordmark (pill mode) or inline nav (flat mode) --- {%- endcomment -%}
    {% if style == 'pill' %}
      <a href="{{ routes.root_url }}" class="header__wordmark header__wordmark--center" aria-label="{{ shop.name }}">
        {{ shop.name | upcase }}
      </a>
    {% else %}
      <nav class="header__flat-nav hidden lg:flex" aria-label="Primary">
        {% if menu != blank %}
          {% for link in menu.links %}
            <a href="{{ link.url }}" class="header__flat-item"{% if link.current %} aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          {% endfor %}
        {% endif %}
      </nav>
    {% endif %}

    {%- comment -%} Mobile wordmark (always centered on mobile) {%- endcomment -%}
    {% if style == 'flat' %}
      <a href="{{ routes.root_url }}" class="header__wordmark header__wordmark--mobile lg:hidden" aria-label="{{ shop.name }}">
        {{ shop.name | upcase }}
      </a>
    {% endif %}

    {%- comment -%} --- Right: utility pill group (Search / Account / Bag) --- {%- endcomment -%}
    {% if style == 'pill' %}
      <div
        id="utility-menu-panel"
        class="pill-dropdown pill-dropdown--utility hidden lg:flex"
        data-component="pill-dropdown"
        data-cart-add-key="bag"
      >
        <nav class="pill-dropdown__nav" aria-label="Utility">
          <button
            type="button"
            class="pill-dropdown__item pill-dropdown__item--toggle"
            data-pill-toggle
            data-panel-key="search"
            aria-controls="utility-menu-panel-search"
            aria-expanded="false"
          >Search</button>
          <span class="pill-dropdown__divider" aria-hidden="true"></span>
          <button
            type="button"
            class="pill-dropdown__item pill-dropdown__item--toggle"
            data-pill-toggle
            data-panel-key="account"
            aria-controls="utility-menu-panel-account"
            aria-expanded="false"
          >{{ 'layout.customer.account' | t }}</button>
          <span class="pill-dropdown__divider" aria-hidden="true"></span>
          <button
            type="button"
            class="pill-dropdown__item pill-dropdown__item--toggle"
            data-pill-toggle
            data-panel-key="bag"
            aria-controls="utility-menu-panel-bag"
            aria-expanded="false"
          >
            <span data-component="header-cart-control">
              Bag (<span data-count>{{ cart.item_count }}</span>)
            </span>
          </button>
        </nav>

        <div
          id="utility-menu-panel-search"
          class="pill-dropdown__panel pill-dropdown__panel--search"
          data-panel-key="search"
        >
          <div class="pill-dropdown__panel-inner">
            {% render 'search-inline', id: section.id | append: '-search' %}
          </div>
        </div>

        <div
          id="utility-menu-panel-account"
          class="pill-dropdown__panel pill-dropdown__panel--account"
          data-panel-key="account"
        >
          <div class="pill-dropdown__panel-inner">
            {% render 'customer-login-inline' %}
          </div>
        </div>

        <div
          id="utility-menu-panel-bag"
          class="pill-dropdown__panel pill-dropdown__panel--bag"
          data-panel-key="bag"
          data-header-cart-panel
        >
          <div class="pill-dropdown__panel-inner">
            {% render 'cart-body' %}
            {% render 'cart-footer', threshold: settings.free_shipping_threshold %}
            <script type="application/json" data-cart-json>
              {% render 'cart-json' %}
            </script>
          </div>
        </div>
      </div>
    {% else %}
      <nav class="header__flat-nav header__flat-nav--utility hidden lg:flex" aria-label="Utility">
        <a href="{{ routes.search_url }}" class="header__flat-item">Search</a>
        <button
          type="button"
          class="header__flat-item"
          data-ajax-cart-toggle
          aria-label="Toggle bag"
          aria-controls="ajax-cart"
          aria-expanded="false"
        >
          <span data-component="header-cart-control">
            Bag (<span data-count>{{ cart.item_count }}</span>)
          </span>
        </button>
      </nav>
    {% endif %}

    {%- comment -%} Mobile cart pill (right) {%- endcomment -%}
    <div class="header__mobile-right lg:hidden">
      <button
        type="button"
        class="header__pill-btn"
        data-ajax-cart-toggle
        aria-label="Toggle bag"
        aria-controls="ajax-cart"
        aria-expanded="false"
      >
        <span class="pill-dropdown__item" data-component="header-cart-control">
          Bag (<span data-count>{{ cart.item_count }}</span>)
        </span>
      </button>
    </div>
  </div>

</header>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if shop.brand.logo %}
      "logo": {{ shop.brand.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_link_twitter   | json }},
      {{ settings.social_link_facebook  | json }},
      {{ settings.social_link_youtube   | json }},
      {{ settings.social_link_tiktok    | json }},
      {{ settings.social_link_instagram | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Header style",
      "options": [
        { "value": "pill", "label": "Pill (rounded nav + centered wordmark)" },
        { "value": "flat", "label": "Flat (wordmark left + inline nav)" }
      ],
      "default": "pill"
    },
    {
      "type": "paragraph",
      "content": "The primary menu comes from Theme Settings → Navigation. Configure it once there."
    }
  ]
}
{% endschema %}
