{%- comment -%}
  Lookbook CTA
  ------------------------------------------------------------------------------
  Closing call-to-action — text-only link, centered, generous padding.
  Simplified from the original image-with-overlay treatment because the
  big editorial image was competing with the lookbook-block images above
  and reading as "yet another hero". A quiet text link "Shop the drop →"
  reads as the deliberate close of the editorial story.

  Figma node (original): 148:167
{%- endcomment -%}

{%- liquid
  assign link = section.settings.link
  assign label = section.settings.label | default: 'Shop the collection'
-%}

<section
  data-section-id="{{ section.id }}"
  data-section-type="lookbook-cta"
  class="w-full px-2 py-16 lg:py-24 flex justify-center"
>
  {%- if link != blank -%}
    <a
      href="{{ link }}"
      class="text-h2 text-fg inline-flex items-center gap-3 transition-opacity duration-200 hover:opacity-70"
    >{{ label }} <span aria-hidden="true">→</span></a>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Lookbook CTA",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "CTA label",
      "default": "Shop the drop"
    },
    {
      "type": "url",
      "id": "link",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "Lookbook CTA"
    }
  ]
}
{% endschema %}
