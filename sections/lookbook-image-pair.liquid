{%- comment -%}
  Lookbook Image Pair
  ------------------------------------------------------------------------------
  Two-image editorial composition: small portrait left (400×520) + large
  square right (720×720) on desktop, justify-between with bottom alignment
  so the small image hangs above the bottom edge of the large square.

  Mobile stacks both images full-width — to be tuned in the mobile pass.

  Figma node: 148:112
{%- endcomment -%}

{%- liquid
  assign small_focal = section.settings.small_image.presentation.focal_point | default: 'center center'
  assign small_style = 'object-position: ' | append: small_focal
  assign large_focal = section.settings.large_image.presentation.focal_point | default: 'center center'
  assign large_style = 'object-position: ' | append: large_focal
-%}

<section
  data-section-id="{{ section.id }}"
  data-section-type="lookbook-image-pair"
  class="flex flex-col lg:flex-row lg:items-end lg:justify-between lg:h-[720px] lg:pb-20"
>
  {%- comment -%}
    Mobile: images stack flush (no gap, no padding) per updated Figma node
    149:177 — small at 420px, large at 520px. Desktop: small (400×520) sits
    bottom-left, large (720×720) sits bottom-right with justify-between.
  {%- endcomment -%}
  {%- if section.settings.small_image != blank -%}
    <div class="w-full h-[420px] bg-bg-surface lg:w-[400px] lg:h-[520px] shrink-0">
      {{ section.settings.small_image
        | image_url: width: 800
        | image_tag:
          loading: 'lazy',
          widths: '400,800,1200',
          sizes: '(min-width: 1024px) 400px, 100vw',
          class: 'w-full h-full object-cover block',
          style: small_style,
          alt: section.settings.small_image.alt | default: ''
      }}
    </div>
  {%- endif -%}

  {%- if section.settings.large_image != blank -%}
    <div class="w-full h-[520px] bg-bg-surface lg:w-[720px] lg:h-[720px] shrink-0">
      {{ section.settings.large_image
        | image_url: width: 1440
        | image_tag:
          loading: 'lazy',
          widths: '720,1440',
          sizes: '(min-width: 1024px) 720px, 100vw',
          class: 'w-full h-full object-cover block',
          style: large_style,
          alt: section.settings.large_image.alt | default: ''
      }}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Lookbook Image Pair",
  "settings": [
    {
      "type": "image_picker",
      "id": "small_image",
      "label": "Small image (left)",
      "info": "Renders at 400×520 on desktop. Use a portrait crop."
    },
    {
      "type": "image_picker",
      "id": "large_image",
      "label": "Large image (right)",
      "info": "Renders at 720×720 on desktop. Use a square crop."
    }
  ],
  "presets": [
    {
      "name": "Lookbook Image Pair"
    }
  ]
}
{% endschema %}
