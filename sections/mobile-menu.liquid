<div data-section-id="{{ section.id }}" data-section-type="mobile-menu">
  <div
    id="{{ section.id }}"
    class="drawer mobile-menu"
    data-component="mobile-menu-drawer"
    aria-hidden="true"
    role="dialog"
    aria-label="Menu"
    inert
  >
    {%- liquid
      assign menu = settings.primary_menu
      assign secondary = settings.secondary_menu
      assign social = settings.social_menu
    -%}

    <button
      type="button"
      class="mobile-menu__close"
      data-close
      aria-label="Close menu"
    >&times;</button>

    <div class="mobile-menu__scroller" data-scroller>
      {%- comment -%} --- Primary nav (big headings + inline accordion) --- {%- endcomment -%}
      <nav class="mobile-menu__primary" aria-label="Primary">
        {% if menu != blank %}
          {% for link in menu.links %}
            <div class="mobile-menu__primary-item">
              {% if link.links.size > 0 %}
                <button
                  type="button"
                  class="mobile-menu__primary-link mobile-menu__primary-link--toggle"
                  data-mobile-menu-toggle
                  data-panel-key="{{ forloop.index0 }}"
                  aria-controls="mobile-menu-panel-{{ forloop.index0 }}"
                  aria-expanded="false"
                >
                  <span>{{ link.title }}</span>
                  <span class="mobile-menu__caret" aria-hidden="true">▾</span>
                </button>
                <ul
                  id="mobile-menu-panel-{{ forloop.index0 }}"
                  class="mobile-menu__categories"
                  data-panel-key="{{ forloop.index0 }}"
                  role="menu"
                >
                  {% for sublink in link.links %}
                    <li role="none">
                      <a
                        href="{{ sublink.url }}"
                        class="mobile-menu__category"
                        role="menuitem"
                        {% if sublink.current %}aria-current="page"{% endif %}
                      >{{ sublink.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% else %}
                <a
                  href="{{ link.url }}"
                  class="mobile-menu__primary-link"
                  {% if link.current %}aria-current="page"{% endif %}
                >{{ link.title }}</a>
              {% endif %}
            </div>
          {% endfor %}
        {% endif %}
      </nav>

      <div class="mobile-menu__divider" aria-hidden="true"></div>

      {%- comment -%} --- Search --- {%- endcomment -%}
      <form action="{{ routes.search_url }}" method="get" class="mobile-menu__search" role="search">
        <input
          type="search"
          name="q"
          placeholder="{{ 'general.search.placeholder' | t }}"
          class="mobile-menu__search-input"
          autocomplete="off"
          aria-label="{{ 'general.search.title' | t }}"
        >
      </form>

      {%- comment -%} --- Secondary nav (smaller, 12px uppercase) --- {%- endcomment -%}
      {% if secondary != blank and secondary.links.size > 0 %}
        <nav class="mobile-menu__secondary" aria-label="Secondary">
          {% for link in secondary.links %}
            <a
              href="{{ link.url }}"
              class="mobile-menu__secondary-link"
              {% if link.current %}aria-current="page"{% endif %}
            >{{ link.title }}</a>
          {% endfor %}
        </nav>
      {% endif %}

      <div class="mobile-menu__spacer"></div>

      {%- comment -%} --- Social (bottom) --- {%- endcomment -%}
      {% if social != blank and social.links.size > 0 %}
        <nav class="mobile-menu__social" aria-label="Social">
          {% for link in social.links %}
            <a
              href="{{ link.url }}"
              class="mobile-menu__social-link"
              target="_blank"
              rel="noopener"
            >{{ link.title }}</a>
          {% endfor %}
        </nav>
      {% endif %}
    </div>

    {%- comment -%} Inline search component — required by MobileMenuDrawer JS {%- endcomment -%}
    <div class="sr-only">
      {%- liquid
        assign id = section.id | append: '-search'
        render 'search-inline', id: id
      -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Mobile Menu",
  "settings": [
    {
      "type": "paragraph",
      "content": "All menus come from Theme Settings → Navigation. Configure them once there."
    }
  ]
}
{% endschema %}
