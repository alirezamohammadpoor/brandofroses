{%- comment %}

  Collection Main Section
  ------------------------------------------------------------------------------
  Hero + filter bar + structured product grid (rows 1–3 with optional
  editorial images) + overflow grid for products beyond the structured 12.

  Pagination: intentionally none. The catalog is small enough to render in
  full on a single page (Shopify's default collection.products limit is 50,
  which comfortably covers Brand of Roses). If the catalog grows past that,
  reintroduce `{% paginate collection.products by N %}` and wire the
  `.results-display` component back in for infinite scroll.

{% endcomment -%}

{%- liquid
  assign hero_image = section.settings.hero_image | default: collection.image
  assign total_products = collection.products.size

  comment
    Count editorial blocks with images
  endcomment
  assign editorial_count = 0
  for block in section.blocks
    if block.type == 'editorial' and block.settings.image != blank
      assign editorial_count = editorial_count | plus: 1
    endif
  endfor
-%}

<div data-section-id="{{ section.id }}" data-section-type="collection">

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  {% if section.settings.show_hero %}
    <div class="flex flex-col gap-4 px-2 py-10 lg:flex-row lg:items-stretch lg:gap-0 lg:py-16 lg:px-2">
      <div class="flex flex-col gap-4 lg:w-1/2 lg:pr-2">
        <h1 class="text-h2 font-light text-fg">{{ collection.title }}</h1>
        {% if collection.description != blank %}
          <p class="text-body text-fg lg:text-muted max-w-[300px] lg:max-w-[400px]">
            {{ collection.description }}
          </p>
        {% endif %}
      </div>
      {% if hero_image %}
        <div class="w-full overflow-hidden bg-[#d9d4cc] lg:w-1/2 lg:h-auto">
          {{ hero_image
            | image_url: width: 1440
            | image_tag:
              loading: 'eager',
              class: 'w-full h-full object-cover lazy-image',
              sizes: '(max-width: 1023.98px) 100vw, 50vw'
          }}
        </div>
      {% endif %}
    </div>
  {% endif %}

  {%- comment -%} ===== FILTERABLE RESULTS =====
    Wrap everything that should refresh on filter/sort in a single container.
    CollectionSection's AJAX handler swaps this element's innerHTML with the
    freshly-rendered server response — keeps the hero in place and avoids a
    full page navigation.

    A11y: `role="region"` + `aria-label` gives screen readers a named
    landmark. `aria-live="polite"` announces updates without stealing focus.
    `aria-busy` is flipped to "true" during an in-flight fetch in
    CollectionSection.
  {%- endcomment -%}
  <div
    data-collection-results
    role="region"
    aria-label="{{ collection.title | escape }}"
    aria-live="polite"
    aria-busy="false"
  >

  {%- comment -%} ===== TOOLBAR (filter + sort) ===== {%- endcomment -%}
  {% render 'collection-toolbar' %}

  {%- comment -%} ===== PRODUCT COUNT =====
    The span already lives inside the `aria-live="polite"` results region, so
    SR users hear the new count when filters change.
  {%- endcomment -%}
  <div class="flex justify-end items-center px-2 py-6 lg:py-8">
    <span class="text-[12px] text-fg lg:text-muted">
      {{ collection.products_count }} {{ 'collections.general.products' | t }}
    </span>
  </div>

  {%- comment -%} ===== STRUCTURED GRID (rows 1–3, first 12 products) ===== {%- endcomment -%}
  {% if total_products > 0 %}
    <div class="flex flex-col gap-[var(--section-spacing-y)] px-2">

      {%- comment -%} === ROW 1: first 4 products (always plain 4-col) === {%- endcomment -%}
      <ul class="grid grid-cols-2 lg:grid-cols-4 gap-x-1 gap-y-[var(--section-spacing-y)]">
        {% for product in collection.products limit: 4 %}
          <li>{% render 'product-card', product: product, loading: 'eager', collection: collection %}</li>
        {% endfor %}
      </ul>

      {%- comment -%} === ROW 2: editorial[0] + products 5-8 === {%- endcomment -%}
      {% if total_products > 4 %}
        {% if editorial_count > 0 %}
          {%- assign ed_block = section.blocks[0] -%}
          {%- assign ed_link = ed_block.settings.product.url | default: '' -%}
          {%- comment -%} Mobile: editorial then grid {%- endcomment -%}
          <div class="lg:hidden flex flex-col gap-1">
            {% if ed_link != blank %}<a href="{{ ed_link }}" class="block">{% endif %}
            <div class="w-full h-[80dvh] overflow-hidden bg-[#d9d4cc]">
              {{ ed_block.settings.image | image_url: width: 780 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover lazy-image', sizes: '100vw' }}
            </div>
            {% if ed_link != blank %}</a>{% endif %}
            <ul class="grid grid-cols-2 gap-x-1 gap-y-[var(--section-spacing-y)]">
              {% for product in collection.products limit: 4 offset: 4 %}
                <li>{% render 'product-card', product: product, loading: 'eager', collection: collection %}</li>
              {% endfor %}
            </ul>
          </div>
          {%- comment -%} Desktop: image LEFT, products RIGHT — stretches to match 2×2 grid {%- endcomment -%}
          <div class="hidden lg:flex lg:items-stretch lg:gap-1">
            {% if ed_link != blank %}<a href="{{ ed_link }}" class="w-1/2 shrink-0">{% endif %}
            <div class="{% if ed_link == blank %}w-1/2 shrink-0{% endif %} overflow-hidden bg-[#d9d4cc] h-full">
              {{ ed_block.settings.image | image_url: width: 1420 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover lazy-image', sizes: '50vw' }}
            </div>
            {% if ed_link != blank %}</a>{% endif %}
            <ul class="flex-1 grid grid-cols-2 gap-x-1 gap-y-[var(--section-spacing-y)]">
              {% for product in collection.products limit: 4 offset: 4 %}
                <li>{% render 'product-card', product: product, loading: 'eager', collection: collection %}</li>
              {% endfor %}
            </ul>
          </div>
        {% else %}
          <ul class="grid grid-cols-2 lg:grid-cols-4 gap-x-1 gap-y-[var(--section-spacing-y)]">
            {% for product in collection.products limit: 4 offset: 4 %}
              <li>{% render 'product-card', product: product, loading: 'eager', collection: collection %}</li>
            {% endfor %}
          </ul>
        {% endif %}
      {% endif %}

      {%- comment -%} === ROW 3: editorial[1] + products 9-12 === {%- endcomment -%}
      {% if total_products > 8 %}
        {% if editorial_count > 1 %}
          {%- assign ed_block = section.blocks[1] -%}
          {%- assign ed_link = ed_block.settings.product.url | default: '' -%}
          {%- comment -%} Mobile: editorial then grid {%- endcomment -%}
          <div class="lg:hidden flex flex-col gap-1">
            {% if ed_link != blank %}<a href="{{ ed_link }}" class="block">{% endif %}
            <div class="w-full h-[80dvh] overflow-hidden bg-[#d9d4cc]">
              {{ ed_block.settings.image | image_url: width: 780 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover lazy-image', sizes: '100vw' }}
            </div>
            {% if ed_link != blank %}</a>{% endif %}
            <ul class="grid grid-cols-2 gap-x-1 gap-y-[var(--section-spacing-y)]">
              {% for product in collection.products limit: 4 offset: 8 %}
                <li>{% render 'product-card', product: product, collection: collection %}</li>
              {% endfor %}
            </ul>
          </div>
          {%- comment -%} Desktop: products LEFT, image RIGHT — stretches to match 2×2 grid {%- endcomment -%}
          <div class="hidden lg:flex lg:items-stretch lg:gap-1">
            <ul class="flex-1 grid grid-cols-2 gap-x-1 gap-y-[var(--section-spacing-y)]">
              {% for product in collection.products limit: 4 offset: 8 %}
                <li>{% render 'product-card', product: product, collection: collection %}</li>
              {% endfor %}
            </ul>
            {% if ed_link != blank %}<a href="{{ ed_link }}" class="w-1/2 shrink-0">{% endif %}
            <div class="{% if ed_link == blank %}w-1/2 shrink-0{% endif %} overflow-hidden bg-[#d9d4cc] h-full">
              {{ ed_block.settings.image | image_url: width: 1420 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover lazy-image', sizes: '50vw' }}
            </div>
            {% if ed_link != blank %}</a>{% endif %}
          </div>
        {% else %}
          <ul class="grid grid-cols-2 lg:grid-cols-4 gap-x-1 gap-y-[var(--section-spacing-y)]">
            {% for product in collection.products limit: 4 offset: 8 %}
              <li>{% render 'product-card', product: product, collection: collection %}</li>
            {% endfor %}
          </ul>
        {% endif %}
      {% endif %}

    </div>

  {% elsif total_products == 0 %}
    <p class="text-center text-[12px] text-muted py-10 px-2">Nothing found.</p>
  {% endif %}

  {%- comment -%} ===== OVERFLOW GRID (products beyond the structured 12) =====
    Plain 4-col (desktop) / 2-col (mobile) grid for anything that didn't fit
    into rows 1–3. No paginate wrapper above — Shopify's default
    `collection.products` limit (50) covers this template's catalog size.

    The `.results-display` wrapper always renders so `CollectionSection`
    (which extends `ResultsSection`) can find its `[data-component]` hook
    on mount. If there are ≤12 products, the wrapper is simply empty.
  {%- endcomment -%}
  <div class="results-display px-2 mt-[var(--section-spacing-y)]" data-component="results-display">
    {% if total_products > 12 %}
      <ul class="grid grid-cols-2 lg:grid-cols-4 gap-x-1 gap-y-[var(--section-spacing-y)]">
        {% for product in collection.products offset: 12 %}
          <li>{% render 'product-card', product: product, collection: collection %}</li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>

  </div>{%- comment -%} /data-collection-results {%- endcomment -%}

</div>

{% schema %}
{
  "name": "Collection - Main",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero section",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero editorial image",
      "info": "Falls back to collection image if not set"
    }
  ],
  "blocks": [
    {
      "type": "editorial",
      "name": "Editorial Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Link to product"
        }
      ]
    }
  ]
}
{% endschema %}
