{%- comment -%}
  Section wrapper gets `lg:hidden` so the entire ajax-cart drawer is
  display:none on desktop. Desktop uses the inline bag pill dropdown
  inside the header instead (see sections/header.liquid bag panel).
  JS still initializes the drawer on desktop but it never opens because
  the toggle button is also lg:hidden — and even if cartAPI's UPDATE
  event triggers an auto-open, it opens an invisible element. Harmless.
{%- endcomment -%}
<div data-section-id="{{ section.id }}" data-section-type="ajax-cart" class="lg:hidden">
  <div
    id="ajax-cart"
    class="ajax-cart overflow-hidden"
    data-component="ajax-cart"
    data-free-shipping-threshold="{{ section.settings.free_shipping_threshold | times: 100 }}"
    aria-hidden="true"
    aria-modal="true"
    role="dialog"
    aria-labelledby="{{ section.id }}-title"
    inert
  >
    <h3 id="{{ section.id }}-title" class="sr-only">{{ 'layout.cart.title' | t }}</h3>

    <form action="{{ routes.cart_url }}" method="post" novalidate class="flex flex-col h-full">
      <div class="ajax-cart__header">
        <span class="text-label text-fg uppercase" data-cart-title>
          {{ 'layout.cart.title' | t | upcase }} ({{ cart.item_count }})
        </span>
        <button
          class="text-fg text-[16px] leading-none"
          data-ajax-cart-close
          type="button"
          aria-label="{{ 'general.close' | t }}"
        >
          &times;
        </button>
      </div>

      <div class="ajax-cart__divider"></div>

      <div class="flex-1 overflow-y-auto">
        {% render 'cart-body' %}
      </div>

      {% render 'cart-footer', threshold: settings.free_shipping_threshold %}
    </form>

    <div class="ajax-cart__empty">
      <div class="ajax-cart__empty-inner">
        <p class="text-body text-fg">{{ 'ajax_cart.general.empty_title' | t }}</p>
        <a
          href="{{ routes.all_products_collection_url }}"
          class="text-label text-fg"
        >{{ 'ajax_cart.general.empty_cta' | t }} &rarr;</a>
      </div>
    </div>
  </div>

  <script type="application/json" data-cart-json>
    {% render 'cart-json' %}
  </script>
</div>

{% schema %}
{
  "name": "Ajax Cart",
  "settings": [
    {
      "type": "paragraph",
      "content": "The free shipping threshold lives in Theme Settings \u2192 Cart so the same value applies to both the mobile drawer and the desktop bag panel."
    }
  ]
}
{% endschema %}
